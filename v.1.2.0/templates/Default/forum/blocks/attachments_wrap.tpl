<div class="df-attachments-container">
    <div class="df-att-header">
        <i class="fa fa-paperclip"></i> {att_label} <span class="df-att-count">({att_count})</span>
    </div>

    [has-images]
    <div class="df-att-images-grid">
        {att_images}
    </div>
    [/has-images]

    [has-files]
    <div class="df-att-files-list">
        {att_files}
    </div>
    [/has-files]
</div>
