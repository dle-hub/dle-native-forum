<div class="df-att-file-card">
    <div class="df-att-file-info">
        <div class="df-att-file-icon">
            <i class="fa fa-file-zip-o"></i>
        </div>
        <div class="df-att-file-details">
            <a href="{att_url}" class="df-att-file-name">{att_name}</a>
            <span class="df-att-file-size">{att_size}</span>
        </div>
    </div>
    <div class="df-att-file-actions">
        <a href="{att_url}" class="df-btn df-btn-sm df-btn-outline" title="İndir">
            <i class="fa fa-download"></i>
        </a>
    </div>
</div>
