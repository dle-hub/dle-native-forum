<IfModule mod_authz_core.c>
    Require all denied
</IfModule>
<IfModule !mod_authz_core.c>
   Order allow,deny
   Deny from all
</IfModule>

<FilesMatch "\.(css|js|png|jpg|gif|svg|webp|ico)$|^$">
   <IfModule mod_authz_core.c>
       Require all granted
   </IfModule>
   <IfModule !mod_authz_core.c>
      Order deny,allow
      Allow from all
   </IfModule>
</FilesMatch>
