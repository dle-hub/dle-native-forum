<div class="df-user-post-row">
  <div class="df-user-post-title">
    <a href="{post_url}">{post_title}</a>
  </div>
  <div class="df-user-post-meta">
    <span class="df-user-post-cat">
      <i class="fa fa-folder"></i> <a href="{cat_url}">{cat_name}</a>
    </span>
    <span class="df-user-post-date">
      <i class="fa fa-clock-o"></i> {post_date}
    </span>
  </div>
  <div class="df-user-post-preview">
    {post_preview}
  </div>
</div>
