<div class="df-notif-row">
  <div class="df-notif-icon" style="color:{notif_color}">
    <i class="fa {notif_icon}"></i>
  </div>
  <div class="df-notif-body">
    <span class="df-notif-from">{notif_from}</span>
    <span class="df-notif-action">{notif_action}</span>
    [has-link]
    <a href="{notif_url}" class="df-notif-topic">{notif_topic}</a>
    [/has-link]
    [no-link]
    <span class="df-notif-topic">{notif_topic}</span>
    [/no-link]
    <div class="df-notif-date">{notif_date}</div>
  </div>
</div>
